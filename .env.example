# Base RPC endpoint (default: https://mainnet.base.org)
BASE_RPC_URL=https://mainnet.base.org

# Wallet private key (hex, without 0x prefix)
PRIVATE_KEY=

# Anthropic API key for AI reasoning
ANTHROPIC_API_KEY=

# Risk parameters (optional overrides)
# MAX_POSITION_USD=500
# MAX_DRAWDOWN_PCT=5
# PER_TRADE_LOSS_LIMIT_USD=50
# COOLDOWN_MS=60000

# Polling interval in milliseconds (default: 15000)
# POLL_INTERVAL_MS=15000
